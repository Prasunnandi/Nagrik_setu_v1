# ============================================================
# NAGRIK SETU — Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================================

# ── Gemini AI (REQUIRED) ──────────────────────────────────
# Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Maps (REQUIRED for live map) ──────────────────
# Get from: console.cloud.google.com → APIs & Services → Maps JavaScript API
# Enable: Maps JavaScript API, Geocoding API, Places API
# Free $200/month credit covers ~40,000 map loads
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ── Firebase (OPTIONAL — localStorage fallback if not set) ──
# Get from: console.firebase.google.com → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Gmail & Sheets OAuth (OPTIONAL — for real email sending) ──
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Enable: Gmail API, Google Sheets API, Google Drive API
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ── Optional Services ─────────────────────────────────────
# Bhashini (Indian languages TTS/ASR) — Free government API
# Register at: bhashini.gov.in/ulca/web/sign-up
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_API_KEY=your_bhashini_api_key

# ============================================================
# QUICK START (minimum to run the demo):
# 1. Set GEMINI_API_KEY → chat works with all features
# 2. Set NEXT_PUBLIC_GOOGLE_MAPS_API_KEY → live map works
# 3. Everything else → uses free fallbacks (localStorage, CSV)
# ============================================================
